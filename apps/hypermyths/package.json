{
  "name": "hypercinema",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.7",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "db:migrate": "prisma migrate deploy",
    "start": "node .next/standalone/server.js",
    "worker:dev": "tsx workers/server.ts",
    "worker:poll": "tsx worker-poll.ts",
    "worker:start": "NODE_ENV=production tsx workers/server.ts",
    "worker:start:poll": "NODE_ENV=production tsx worker-poll.ts",
    "postinstall": "prisma generate",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:live": "vitest run tests/live.external-smoke.test.ts",
    "test:ci": "vitest run --reporter=default",
    "env:check": "node scripts/validate-env.mjs",
    "secrets:scan": "node scripts/scan-secrets.mjs",
    "video:dev": "tsx video-service/src/main.ts",
    "video:build": "tsc -p video-service/tsconfig.json",
    "video:start": "node video-service/dist/main.js"
  },
