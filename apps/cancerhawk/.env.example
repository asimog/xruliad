# Shared
DATABASE_URL=
NEXT_PUBLIC_APP_URL=http://localhost:3002
NEXT_PUBLIC_PRODUCT_ID=cancerhawk
OPENROUTER_API_KEY=
AI_PROVIDER_API_KEY=

# CancerHawk
CANCERHAWK_BACKEND_URL=http://localhost:8765
CANCERHAWK_CORS_ORIGINS=http://localhost:3002
CANCERHAWK_PUBLIC_BASE_URL=http://localhost:3002
NEXT_PUBLIC_BACKEND_URL=http://localhost:8765
GITHUB_TOKEN=
GITHUB_REPO=
GITHUB_BRANCH=master
GIT_COMMITTER_NAME=hermes-agent
GIT_COMMITTER_EMAIL=hermes@cancerhawk.local
HERMES_AUTO_GENERATE_ENABLED=false

# pay.sh
PAYSH_API_BASE_URL=
PAYSH_WALLET_PRIVATE_KEY=
PAYSH_NETWORK=base
PAYSH_DEFAULT_CURRENCY=USDC
PAYSH_MAX_REQUEST_COST=1
PAYSH_DAILY_SPEND_LIMIT=25

# MiroShark
MIROSHARK_BASE_URL=
MIROSHARK_API_KEY=
MIROSHARK_DOCKER_ENABLED=false
MIROSHARK_DEFAULT_MODEL=
MIROSHARK_MAX_AGENTS=250
MIROSHARK_MAX_SIMULATION_HOURS=24

# Moto / fstack
MOTO_BASE_PATH=
MOTO_DOCKER_ENABLED=false
MOTO_DEFAULT_AGENT=codex
MOTO_LOG_LEVEL=info

# Audio / visuals
NEXT_PUBLIC_ENABLE_MUSIC_ORB=true
NEXT_PUBLIC_ENABLE_BACKGROUND_ANIMATION=true
NEXT_PUBLIC_DEFAULT_AUDIO_MUTED=true

# Final local/web runtime
APP_RUNTIME_MODE=web
DEPLOYMENT_TARGET=vercel
ENABLE_WEB_FEATURES=true
ENABLE_CLOUD_INFERENCE=true
NEXT_PUBLIC_DEFAULT_RUNTIME_MODE=web
NEXT_PUBLIC_ENABLE_QVAC_LOCAL_CONNECT=true
PLATFORM_PAYSH_API_BASE_URL=
PLATFORM_PAYSH_WALLET_PRIVATE_KEY=
QVAC_MODE=optional
