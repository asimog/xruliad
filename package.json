{
  "name": "hypermyths-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "dev:hypermyths": "pnpm --filter hypercinema dev",
    "dev:hashmyth": "pnpm --filter @hypermyths/hashmyth dev",
    "dev:hypertian": "pnpm --filter hypertian dev",
    "dev:cancerhawk": "pnpm --filter cancerhawk-web dev",
    "dev:hyperkaon": "pnpm --filter @hypermyths/hyperkaon dev",
    "dev:polymyths": "pnpm --filter @hypermyths/polymyths dev",
    "build:hypermyths": "pnpm --filter hypercinema build",
    "build:hashmyth": "pnpm --filter @hypermyths/hashmyth build",
    "build:hypertian": "pnpm --filter hypertian build",
    "build:cancerhawk": "pnpm --filter cancerhawk-web build",
    "build:hyperkaon": "pnpm --filter @hypermyths/hyperkaon build",
    "build:polymyths": "pnpm --filter @hypermyths/polymyths build",
    "worker:intelligence": "pnpm --filter @hypermyths/intelligence-worker start",
    "worker:simulation": "pnpm --filter @hypermyths/simulation-worker start",
    "worker:video": "pnpm --filter @hypermyths/video-worker start",
    "worker:synthetic-data": "pnpm --filter @hypermyths/synthetic-data-worker start",
    "worker:ads": "pnpm --filter @hypermyths/ad-server start",
    "runtime:check": "pnpm --filter @hypermyths/runtime check",
    "privacy:test": "pnpm --filter @hypermyths/privacy test",
    "qvac:check": "pnpm --filter @hypermyths/qvac check",
    "qvac:gateway": "pnpm --filter @hypermyths/qvac-gateway start",
    "qvac:hybrid:test": "pnpm qvac:check && pnpm inference:test",
    "platform-payments:check": "pnpm --filter @hypermyths/platform-payments check",
    "user-local-payments:check": "pnpm --filter @hypermyths/user-local-payments check",
    "paysh:check": "pnpm --filter @hypermyths/payments check",
    "x402scan:check": "pnpm --filter @hypermyths/x402-discovery check",
    "inference:test": "pnpm --filter @hypermyths/inference-router test",
    "command-protocol:test": "pnpm --filter @hypermyths/command-protocol test",
    "thesis-engine:test": "pnpm --filter @hypermyths/thesis-engine test",
    "local-trading:check": "pnpm --filter @hypermyths/local-trading check",
    "execution:safety:test": "pnpm --filter @hypermyths/execution test",
    "encrypt:check": "pnpm --filter @hypermyths/encrypt check",
    "ika:check": "pnpm --filter @hypermyths/ika check",
    "display:test": "pnpm --filter @hypermyths/display test",
    "hackathon:check": "node scripts/hackathon-check.mjs",
    "final-demo:check": "pnpm --filter hypercinema typecheck && pnpm hackathon:check",
    "miroshark:check": "pnpm --filter @hypermyths/simulation check",
    "moto:check": "pnpm --filter @hypermyths/agents check",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "pnpm --filter @hypermyths/supabase check",
    "supabase:types": "supabase gen types typescript --local --schema public > packages/supabase/src/types.gen.ts || echo 'supabase CLI not available — skip type gen'",
    "memory:local:check": "pnpm --filter @hypermyths/agent-memory test",
    "memory:cloud:check": "pnpm --filter @hypermyths/agent-memory test",
    "memory:policy:test": "pnpm --filter @hypermyths/agent-memory test",
    "memory:sync:test": "pnpm --filter @hypermyths/memory-sync test",
    "vector-memory:test": "pnpm --filter @hypermyths/vector-memory test",
    "github:check": "pnpm --filter @hypermyths/github-agent check",
    "github:policy:test": "pnpm --filter @hypermyths/github-agent check",
    "github:artifact:test": "pnpm --filter @hypermyths/artifact-ledger test",
    "artifact-ledger:test": "pnpm --filter @hypermyths/artifact-ledger test",
    "agent-memory:test": "pnpm --filter @hypermyths/agent-memory test",
    "feed:check": "pnpm --filter @hypermyths/unified-feed test",
    "feed:privacy:test": "pnpm --filter @hypermyths/feed-privacy test",
    "feed:schema:test": "pnpm --filter @hypermyths/unified-feed test",
    "feed:sync:test": "pnpm --filter @hypermyths/feed-events test",
    "feed:ui:check": "echo 'Feed UI components compile — verify via pnpm typecheck'",
    "belief-engine:test": "pnpm --filter @hypermyths/belief-engine test",
    "openrouter:byok:test": "pnpm --filter @hypermyths/openrouter check",
    "paysh:simple:test": "pnpm --filter @hypermyths/byok check",
    "setup:check": "pnpm --filter @hypermyths/belief-engine test",
    "rbm-belief-demo:check": "pnpm --filter @hypermyths/belief-engine test"
  },
  "devDependencies": {
    "turbo": "^2.6.1",
    "typescript": "^5.9.3",
    "tsx": "^4.20.6"
  }
}
