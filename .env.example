# Runtime
APP_RUNTIME_MODE=web
DEPLOYMENT_TARGET=vercel
ENABLE_WEB_FEATURES=true
ENABLE_LOCAL_TRADING=true
ENABLE_QVAC_LOCAL_CONNECT=true
ENABLE_CLOUD_INFERENCE=true
ENABLE_HYBRID_QVAC=true
NEXT_PUBLIC_DEFAULT_RUNTIME_MODE=web
NEXT_PUBLIC_ENABLE_QVAC_LOCAL_CONNECT=true
NEXT_PUBLIC_ENABLE_CLOUD_INFERENCE=true
NEXT_PUBLIC_ENABLE_LOCAL_TRADING_CONNECT=true

# QVAC
QVAC_ENABLED=true
QVAC_MODE=optional
QVAC_BASE_URL=http://localhost:11434/v1
QVAC_GATEWAY_URL=http://localhost:8787
QVAC_API_KEY=local-qvac-key
QVAC_DEFAULT_MODEL=
QVAC_EMBEDDING_MODEL=
QVAC_PAIRING_REQUIRED=true
QVAC_REQUIRE_LOCAL_FOR_PRIVATE=true
QVAC_ALLOW_REMOTE_FALLBACK=false

# Platform pay.sh
PLATFORM_PAYSH_API_BASE_URL=
PLATFORM_PAYSH_WALLET_PRIVATE_KEY=
PLATFORM_PAYSH_NETWORK=
PLATFORM_PAYSH_DEFAULT_CURRENCY=
PLATFORM_PAYSH_RECEIPTS_PUBLIC=true
PLATFORM_PAYSH_MAX_JOB_COST=
PLATFORM_PAYSH_DAILY_SPEND_LIMIT=

# User-local pay.sh
USER_PAYSH_API_BASE_URL=
USER_PAYSH_WALLET_PRIVATE_KEY=
USER_PAYSH_NETWORK=
USER_PAYSH_DEFAULT_CURRENCY=
USER_PAYSH_MAX_REQUEST_COST=
USER_PAYSH_DAILY_SPEND_LIMIT=
USER_PAYSH_LOCAL_ONLY=true

# x402
X402_ENABLED=true
X402SCAN_BASE_URL=https://www.x402scan.com
X402SCAN_API_BASE_URL=
X402_DEFAULT_FACILITATOR=
X402_MAX_REQUEST_COST=
X402_DAILY_SPEND_LIMIT=

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_ALLOW_FREE=true
OPENROUTER_ALLOW_PAID=true
OPENROUTER_MAX_REQUEST_COST=
OPENROUTER_DEFAULT_MODEL=deepseek/deepseek-v4-pro
OPENROUTER_FREE_MODEL=deepseek/deepseek-v4-pro

# Encrypt / Ika
ENCRYPT_ENABLED=false
ENCRYPT_RPC_URL=
ENCRYPT_PROGRAM_ID=
ENCRYPT_NETWORK=devnet
ENCRYPT_LOCAL_FALLBACK=true
IKA_ENABLED=false
IKA_RPC_URL=
IKA_NETWORK=devnet
IKA_PROGRAM_ID=
IKA_DWALLET_ID=
IKA_POLICY_ID=

# Local strategy/trading
STRATEGY_VAULT_LOCAL_ONLY=true
STRATEGY_VAULT_KEY=
EXECUTION_MODE=web_prepare_only
REQUIRE_USER_APPROVAL=true
MAX_TRADE_SIZE=
DAILY_TRADE_LIMIT=
ALLOWED_VENUES=
ALLOWED_ASSETS=
LOCAL_EXECUTION_GATEWAY_URL=http://localhost:8790
LOCAL_EXECUTION_PAIRING_REQUIRED=true

# Supabase (Cloud)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_STORAGE_PUBLIC_BUCKET=public-artifacts
SUPABASE_STORAGE_PRIVATE_BUCKET=private-artifacts

# Local Supabase (MythVault)
LOCAL_SUPABASE_URL=http://127.0.0.1:54321
LOCAL_SUPABASE_ANON_KEY=
LOCAL_SUPABASE_SERVICE_ROLE_KEY=
LOCAL_SUPABASE_DB_URL=
LOCAL_MEMORY_ENABLED=true
LOCAL_MEMORY_DEFAULT=true

# Memory configuration
MEMORY_MODE=hybrid
MEMORY_REQUIRE_APPROVAL_FOR_CLOUD_SYNC=true
MEMORY_ENABLE_VECTOR=true
MEMORY_DEFAULT_VISIBILITY=private
MEMORY_BLOCK_KEY_MATERIAL=true
MEMORY_AUTO_SYNC_PUBLIC=true
MEMORY_ENCRYPT_BEFORE_SYNC=false
CLOUD_MEMORY_ENABLED=true

# GitHub App
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_INSTALLATION_ID=
GITHUB_DEFAULT_OWNER=
GITHUB_DEFAULT_REPO=
GITHUB_WEBHOOK_SECRET=
GITHUB_ALLOWED_REPOS=
GITHUB_ARTIFACT_BRANCH=main
GITHUB_CODE_BRANCH_PREFIX=agent/
GITHUB_ALLOW_DIRECT_ARTIFACT_PUBLISH=true
GITHUB_ALLOW_CODE_DIRECT_PUSH=false
GITHUB_ALLOWED_ARTIFACT_PATHS=results/**,public/generated/**,generated/**,reports/**,blocks/**,artifacts/**,docs/generated/**
GITHUB_PROTECTED_PATHS=.env*,secrets/**,private/**,keys/**,.github/workflows/**
GITHUB_TOKEN=

# Artifact publishing
ARTIFACT_PUBLISH_ENABLED=true
ARTIFACT_DIRECT_PATHS=results/**,public/generated/**,generated/**,reports/**,blocks/**,artifacts/**
ARTIFACT_MAX_GITHUB_SIZE_MB=10

# Unified Feed
UNIFIED_FEED_ENABLED=true
UNIFIED_FEED_DEFAULT_VISIBILITY=public
UNIFIED_FEED_LOCAL_ENVELOPES_ENABLED=true
UNIFIED_FEED_REALTIME_ENABLED=true
UNIFIED_FEED_POLL_INTERVAL_MS=5000

# Feed Privacy
FEED_ENCRYPT_LOCAL_ACTORS=true
FEED_ACTOR_ENCRYPTION_KEY=
FEED_LOCAL_PSEUDONYM_SALT=
FEED_CONTENT_ENCRYPTION_KEY=
FEED_LOCAL_JOBS_DEFAULT_MODE=encrypted_public
FEED_LOCAL_TRADING_DEFAULT_MODE=commitment_only
FEED_QVAC_JOBS_DEFAULT_MODE=redacted_public

# Feed Sync
FEED_SYNC_ENABLED=true
FEED_SYNC_REQUIRE_APPROVAL_FOR_PRIVATE=true
FEED_SYNC_ALLOW_LOCAL_ENVELOPES=true

# Public
NEXT_PUBLIC_UNIFIED_FEED_ENABLED=true
NEXT_PUBLIC_UNIFIED_FEED_REALTIME_ENABLED=true

# OpenRouter BYOK
NEXT_PUBLIC_ENABLE_OPENROUTER_BYOK=true
BYOK_OPENROUTER_STORAGE_MODE=browser_local
BYOK_ALLOW_EPHEMERAL_SERVER_USE=true
BYOK_ALLOW_ENCRYPTED_CLOUD_STORAGE=false

# Belief Engine
BELIEF_ENGINE_ENABLED=true
BELIEF_DEFAULT_VISIBILITY=private
BELIEF_PUBLIC_FEED_ENABLED=true
BELIEF_CONFIDENCE_DEFAULT=0.5
BELIEF_RBM_INSPIRED_VISUALS=true

# Public service URLs
NEXT_PUBLIC_TERMINAL_API_URL=
NEXT_PUBLIC_AGENT_ROUTER_URL=
NEXT_PUBLIC_INFERENCE_ROUTER_URL=
NEXT_PUBLIC_PLATFORM_PAYMENTS_URL=
